# Plantilla de variables de entorno del frontend — cópiala a `.env.local` para `next dev`.
# Las variables con prefijo NEXT_PUBLIC_ se exponen en el bundle del navegador.

# Origen de la API del backend (sin la barra final /api/v1). La librería api en
# src/lib/api.ts añade /api/v1 automáticamente.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public origin of this panel (sin trailing slash). Se usa para construir el
# redirect URI del inicio de sesión con Microsoft. Si no se define, cae a
# window.location.origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000
