# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Chatbot RAG API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# ── Security ──────────────────────────────────────────────────────────────────
# REQUERIDO. Genera con: openssl rand -hex 32
SECRET_KEY=<pega-aqui-el-resultado-de-openssl-rand-hex-32>

# Clave Fernet separada para cifrar API keys de proveedores (opcional). Si no se
# define, se deriva de SECRET_KEY. Genera con: openssl rand -hex 32
# ENCRYPTION_KEY=<openssl-rand-hex-32>

# ── Database ──────────────────────────────────────────────────────────────────
# Con Docker Compose (desarrollo):  mysql+aiomysql://chatbot:chatbot@localhost:3306/chatbot
# En servidor sin Docker:           mysql+aiomysql://<usuario>:<contraseña>@<host>:3306/<nombre_db>
DATABASE_URL=mysql+aiomysql://<usuario>:<contraseña>@<host>:3306/<nombre_db>

# Pool de conexiones: máximo simultáneo = DB_POOL_SIZE + DB_MAX_OVERFLOW.
# Se dimensiona generoso a propósito (MySQL soporta cientos de conexiones sin
# problema); la concurrencia real de chats la limita LLM_MAX_CONCURRENCY, no
# este pool. Ver docs/DEPLOYMENT.md §0.1.
# DB_POOL_SIZE=50
# DB_MAX_OVERFLOW=50

# Máximo de conversaciones que usan un proveedor LLM al mismo tiempo. Las que
# exceden ESPERAN en cola (no se rechazan) hasta LLM_QUEUE_TIMEOUT_SECONDS.
# Ajustar según la cuota real del proveedor LLM contratado.
# LLM_MAX_CONCURRENCY=30
# LLM_QUEUE_TIMEOUT_SECONDS=45

# ── Redis ─────────────────────────────────────────────────────────────────────
# Con Docker Compose la URL se inyecta automáticamente y REDIS_PASSWORD se
# define en el .env de la raíz del repo, no aquí. Sin Docker, defina la URL:
REDIS_URL=redis://:<contraseña_redis>@<host>:6379/0

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://<host>:6333
# QDRANT_API_KEY=<api-key-si-usas-qdrant-cloud>

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes desde los que el panel de administración puede hacer peticiones.
# "*" acepta cualquier origin; reemplazar por la lista de dominios reales,
# ej. ["https://uso.edu.sv"].
ALLOWED_ORIGINS=["*"]

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL pública del panel admin (Next.js). El backend la usa para construir
# enlaces que envía por email (invitaciones) — no se deriva de ALLOWED_ORIGINS
# porque ese campo es CORS y puede ser "*" o listar varios orígenes.
FRONTEND_URL=http://localhost:3000

# ── Widget ────────────────────────────────────────────────────────────────────
# URL pública donde se sirve el JS del widget (para mostrar el snippet en la UI).
WIDGET_BASE_URL=http://localhost:8000

# ── Seed — primer admin (solo si no hay usuarios) ─────────────────────────────
FIRST_ADMIN_EMAIL=<tu-email@dominio.com>
# REQUERIDO. Contraseña del primer admin — el sistema no arranca si está vacía.
# Debe ser segura: ≥12 chars con mayúscula, minúscula, dígito y símbolo.
# El admin deberá cambiarla en el primer login.
FIRST_ADMIN_PASSWORD=<contraseña-segura>

# ── Microsoft Azure (SSO + Graph API) ─────────────────────────────────────────
# Permite SSO corporativo y envía correos del sistema (notificaciones,
# escalamientos, invitaciones) mediante Microsoft Graph API.
#
# Requiere una App Registration en portal.azure.com con:
#   - SSO: redirect URI configurado en Autenticación
#   - Graph: permiso de aplicación Mail.Send (con consentimiento admin)
#
# MICROSOFT_CLIENT_ID=<Application (client) ID del portal Azure>
# MICROSOFT_CLIENT_SECRET=<Client secret generado en Azure>
# MICROSOFT_TENANT_ID=<tu-tenant-id>  # o "common" para multitenant
# MICROSOFT_REDIRECT_URI=https://chatbot.usonsonate.edu.sv/api/auth/callback/microsoft
# GRAPH_MAILBOX=<mailbox-con-licencia@tudominio.com>

# ── Comportamiento del chatbot ────────────────────────────────────────────────
# NO se configura aquí. Los parámetros del asistente, las cuotas del chat y el
# caché semántico viven en la base de datos y se editan únicamente desde el
# panel. Este archivo contiene solo infraestructura y secretos.

# Segmentación de documentos, única excepción y leída siempre desde .env:
# cambiar estos valores requiere reingestar todas las fuentes.
CHATBOT_CHUNK_PARENT_SIZE=4000
CHATBOT_CHUNK_CHILD_SIZE=1024
CHATBOT_CHUNK_PARENT_OVERLAP=400
CHATBOT_CHUNK_CHILD_OVERLAP=128

# ── Workers (producción) ──────────────────────────────────────────────────────
# Número de procesos uvicorn. Por defecto: 1.
# Para servidores multi-core usa (2 × núcleos + 1), ej. WORKERS=5 para 2 vCPUs.
# NOTA: el circuit breaker del LLM gateway es por proceso. Con WORKERS>1 cada
# worker mantiene su propio estado; mantén WORKERS=1 salvo que esto sea aceptable.
# WORKERS=1
